<script>
document.addEventListener("DOMContentLoaded", function() {

  var EJES = ['F','O','R','A'];
  var MAX_CASOS = 10;
  var CX = 180, CY = 180, RMAX = 130;
  var rankings = {};
  var casoActual = 1;

  function puntosPos(pos) { return 5 - pos; }

  function calcScores() {
    var s = { F:0, O:0, R:0, A:0 };
    Object.keys(rankings).forEach(function(caso) {
      rankings[caso].forEach(function(item) {
        s[item.eje] += puntosPos(item.pos);
      });
    });
    return s;
  }

  // ── NAVEGACIÓN POR CASOS ─────────────────────────────────────────────────
  function mostrarCaso(n) {
    casoActual = n;
    document.querySelectorAll('.pulso-card').forEach(function(c) { c.classList.remove('activo'); });
    var card = document.querySelector('[data-caso="' + n + '"]');
    if (card) card.classList.add('activo');

    document.getElementById('caso-nav-txt').textContent = n + ' de ' + MAX_CASOS;
    document.getElementById('btn-ant').disabled = (n === 1);
    document.getElementById('btn-sig').disabled = (n === MAX_CASOS);

    document.getElementById('caso-nav').style.display = 'flex';
    document.getElementById('ver-wrap').style.display = 'none';

    if (n === MAX_CASOS) {
      // Show ver-resultados only if all ranked
      actualizarVerBtn();
    }

    window.scrollTo({ top: document.getElementById('p-casos').offsetTop || 0, behavior: 'smooth' });
  }

  function actualizarVerBtn() {
    var respondidos = Object.keys(rankings).length;
    var hint = document.getElementById('ver-hint');
    var btn = document.getElementById('btn-ver-resultados');

    document.getElementById('prog-fill').style.width = Math.round((respondidos/MAX_CASOS)*100) + '%';
    document.getElementById('prog-txt').textContent = respondidos + ' de ' + MAX_CASOS;

    if (casoActual === MAX_CASOS) {
      document.getElementById('caso-nav').style.display = 'none';
      document.getElementById('ver-wrap').style.display = 'block';
      if (respondidos < MAX_CASOS) {
        var falt = MAX_CASOS - respondidos;
        hint.textContent = 'Aún te faltan ' + falt + ' caso' + (falt===1?'':'s') + ' por ordenar — podés volver atrás';
        hint.style.color = '';
        hint.style.fontStyle = 'italic';
        btn.disabled = true;
        btn.style.background = '';
      } else {
        hint.textContent = 'Todos los casos ordenados ✓';
        hint.style.color = 'var(--verde)';
        hint.style.fontStyle = 'normal';
        hint.style.fontWeight = '500';
        btn.disabled = false;
      }
    }
  }

  document.getElementById('btn-sig').addEventListener('click', function() {
    if (casoActual < MAX_CASOS) mostrarCaso(casoActual + 1);
  });

  document.getElementById('btn-ant').addEventListener('click', function() {
    if (casoActual > 1) mostrarCaso(casoActual - 1);
  });

  // ── DRAG FROM HANDLE ONLY ────────────────────────────────────────────────
  var dragSrc = null;

  function updatePositions(lista) {
    lista.querySelectorAll('.ranking-item').forEach(function(item, idx) {
      var pos = idx + 1;
      item.querySelector('.ranking-pos').textContent = pos;
      item.className = 'ranking-item pos-' + pos;
    });
  }

  function saveRanking(lista) {
    var caso = lista.getAttribute('data-caso');
    rankings[caso] = [];
    lista.querySelectorAll('.ranking-item').forEach(function(item, idx) {
      rankings[caso].push({ eje: item.getAttribute('data-eje'), pos: idx + 1 });
    });
    actualizarVerBtn();
  }

  document.querySelectorAll('.ranking-lista').forEach(function(lista) {

    // Mouse drag — initiated from handle
    lista.addEventListener('dragstart', function(e) {
      var handle = e.target.closest('.ranking-handle');
      if (!handle) { e.preventDefault(); return; }
      dragSrc = handle.closest('.ranking-item');
      dragSrc.setAttribute('draggable', true);
      dragSrc.classList.add('dragging');
      e.dataTransfer.effectAllowed = 'move';
    });

    lista.addEventListener('dragend', function(e) {
      if (dragSrc) {
        dragSrc.classList.remove('dragging');
        dragSrc.removeAttribute('draggable');
        dragSrc = null;
      }
      lista.querySelectorAll('.ranking-item').forEach(function(i) { i.classList.remove('drag-over'); });
      updatePositions(lista);
      saveRanking(lista);
    });

    lista.addEventListener('dragover', function(e) {
      e.preventDefault();
      if (!dragSrc) return;
      var target = e.target.closest('.ranking-item');
      if (!target || target === dragSrc) return;
      lista.querySelectorAll('.ranking-item').forEach(function(i) { i.classList.remove('drag-over'); });
      target.classList.add('drag-over');
    });

    lista.addEventListener('drop', function(e) {
      e.preventDefault();
      var target = e.target.closest('.ranking-item');
      if (!target || target === dragSrc || !dragSrc) return;
      var items = Array.from(lista.querySelectorAll('.ranking-item'));
      var srcIdx = items.indexOf(dragSrc);
      var tgtIdx = items.indexOf(target);
      if (srcIdx < tgtIdx) {
        lista.insertBefore(dragSrc, target.nextSibling);
      } else {
        lista.insertBefore(dragSrc, target);
      }
    });

    // Touch drag — initiated from handle only
    var touchItem = null;

    lista.addEventListener('touchstart', function(e) {
      var handle = e.target.closest('.ranking-handle');
      if (!handle) return;
      touchItem = handle.closest('.ranking-item');
      touchItem.classList.add('dragging');
    }, { passive: true });

    lista.addEventListener('touchmove', function(e) {
      if (!touchItem) return;
      e.preventDefault();
      var y = e.touches[0].clientY;
      var items = Array.from(lista.querySelectorAll('.ranking-item:not(.dragging)'));
      var after = items.find(function(item) {
        var box = item.getBoundingClientRect();
        return y < box.top + box.height / 2;
      });
      if (after) { lista.insertBefore(touchItem, after); }
      else { lista.appendChild(touchItem); }
    }, { passive: false });

    lista.addEventListener('touchend', function() {
      if (!touchItem) return;
      touchItem.classList.remove('dragging');
      updatePositions(lista);
      saveRanking(lista);
      touchItem = null;
    }, { passive: true });
  });

  // ── INICIAR ───────────────────────────────────────────────────────────────
  document.getElementById('btn-iniciar').addEventListener('click', function() {
    mostrar('p-casos');
    mostrarCaso(1);
  });

  function mostrar(id) {
    document.querySelectorAll('.pantalla').forEach(function(p) { p.classList.remove('activa'); });
    var el = document.getElementById(id);
    if (el) el.classList.add('activa');
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  // ── VER RESULTADOS ────────────────────────────────────────────────────────
  document.getElementById('btn-ver-resultados').addEventListener('click', function() {
    generarResultados();
    mostrar('p-resultados');
  });

  // ── REINICIAR ─────────────────────────────────────────────────────────────
  document.getElementById('btn-reiniciar').addEventListener('click', function() {
    rankings = {};
    casoActual = 1;
    document.querySelectorAll('.ranking-lista').forEach(function(lista) {
      lista.querySelectorAll('.ranking-item').forEach(function(item, idx) {
        item.querySelector('.ranking-pos').textContent = idx+1;
        item.className = 'ranking-item pos-'+(idx+1);
        item.removeAttribute('draggable');
      });
    });
    document.getElementById('prog-fill').style.width = '0%';
    document.getElementById('prog-txt').textContent = '0 de 10';
    mostrar('p-portada');
  });

  document.getElementById('btn-modulo').addEventListener('click', function() {
    window.location.href = 'PG001_Liderazgo_Cooperativista.html';
  });

  // ── GENERAR RESULTADOS ────────────────────────────────────────────────────
  function generarResultados() {
    var scores = calcScores();
    var total = scores.F + scores.O + scores.R + scores.A;
    var MAX_SCORE = MAX_CASOS * 4;

    function puntoRadar(eje, idx) {
      var val = scores[eje];
      var minR = 20;
      var r = minR + (val / MAX_SCORE) * (RMAX - minR) * 2.8;
      r = Math.min(r, RMAX);
      var ang = ([-90,0,90,180][idx]) * Math.PI / 180;
      return { x: CX + r * Math.cos(ang), y: CY + r * Math.sin(ang) };
    }

    var pts = [puntoRadar('F',0),puntoRadar('O',1),puntoRadar('R',2),puntoRadar('A',3)];
    var t0 = null;
    function lerp(a,b,t){ return a+(b-a)*t; }
    function ease(t){ return 1-Math.pow(1-t,3); }
    function anim(ts) {
      if (!t0) t0 = ts;
      var t = ease(Math.min((ts-t0)/900,1));
      var ap = pts.map(function(p,i){ return {x:lerp(CX,p.x,t),y:lerp(CY,p.y,t)}; });
      document.getElementById('radar-data').setAttribute('points',ap.map(function(p){return p.x.toFixed(1)+','+p.y.toFixed(1);}).join(' '));
      ['dot-F','dot-O','dot-R','dot-A'].forEach(function(id,i){
        var d=document.getElementById(id);
        if(d){d.setAttribute('cx',ap[i].x.toFixed(1));d.setAttribute('cy',ap[i].y.toFixed(1));}
      });
      if((ts-t0)<900) requestAnimationFrame(anim);
    }
    requestAnimationFrame(anim);
    var mR=65;
    document.getElementById('radar-media').setAttribute('points',[[CX,CY-mR],[CX+mR,CY],[CX,CY+mR],[CX-mR,CY]].map(function(p){return p[0]+','+p[1];}).join(' '));

    var nombres={F:'Formativo',O:'Organizacional',R:'Relacional',A:'Adaptativo'};
    var interps={
      F:{alto:'Tu lectura tiende a identificar con claridad los vacíos normativos y formativos. Reconocés cuándo el problema tiene raíz en el desconocimiento de la norma o en la ausencia de formación. Una fortaleza crítica para garantizar que las decisiones sean legítimas.',
         medio:'Tu lectura incorpora la dimensión formativa de forma equilibrada — reconocés cuándo la norma es relevante sin hacerla el único lente de análisis.',
         bajo:'Tu lectura tiende a subvalorar los factores normativos. Algunos problemas que identificás pueden tener raíz en vacíos de conocimiento legal o formativo.'},
      O:{alto:'Tenés sensibilidad aguda para detectar fallas estructurales — procesos mal diseñados, roles ambiguos, sistemas que no funcionan sin personas específicas. Una lectura poderosa para construir organizaciones resilientes.',
         medio:'Tu lectura incorpora la dimensión organizacional sin que domine tu análisis. Reconocés las fallas estructurales cuando son relevantes.',
         bajo:'Tu lectura tiende a subvalorar las causas organizacionales. Algunos conflictos pueden tener origen en estructuras mal diseñadas, no solo en personas.'},
      R:{alto:'Tu lectura es especialmente sensible a las dinámicas humanas — confianza, pertenencia, desconexión emocional. Una fortaleza central para sostener organizaciones donde los vínculos son el activo más frágil.',
         medio:'Incorporás la dimensión relacional de forma equilibrada. Reconocés el factor humano sin que absorba todo el análisis.',
         bajo:'Tu lectura tiende a subvalorar los factores humanos. Prestar más atención a cómo se sienten las personas puede enriquecer significativamente tu diagnóstico.'},
      A:{alto:'Tu lectura identifica con facilidad los desafíos de adaptación y cambio sistémico. Tenés sensibilidad para detectar cuándo la rigidez organizacional está frenando la evolución.',
         medio:'Tu lectura incorpora la dimensión adaptativa de forma balanceada — reconocés cuándo el cambio es el núcleo del problema.',
         bajo:'Tu lectura tiende a subvalorar los factores de cambio. Explorar más esta dimensión puede ampliar tu capacidad de anticipar problemas antes de que escalen.'}
    };

    var grid=document.getElementById('dims-grid');
    grid.innerHTML='';
    var mediaVal=total/4;
    EJES.forEach(function(eje){
      var val=scores[eje];
      var pct=Math.min(Math.round((val/MAX_SCORE)*100*4),100);
      var nivel=val>=mediaVal*1.2?'alto':val>=mediaVal*0.8?'medio':'bajo';
      var d=document.createElement('div');
      d.className='dim-card '+eje;
      d.innerHTML='<div class="dim-head"><span class="dim-letra">'+eje+'</span><span class="dim-nombre">'+nombres[eje]+'</span></div>'
        +'<div class="dim-barra"><div class="dim-fill" style="width:'+pct+'%"></div><div class="dim-media" style="left:50%"></div></div>'
        +'<div class="dim-nums"><span>'+val+' pts</span><span style="color:#c0c0b0">media: '+mediaVal.toFixed(1)+'</span></div>'
        +'<div class="dim-interp">'+interps[eje][nivel]+'</div>';
      grid.appendChild(d);
    });

    var tensiones=[
      {izq:'Norma',      der:'Vínculo',       eI:'F',eD:'R'},
      {izq:'Diseño',     der:'Cultura',        eI:'O',eD:'R'},
      {izq:'Continuidad',der:'Transformación', eI:'O',eD:'A'},
      {izq:'Certeza',    der:'Apertura',       eI:'F',eD:'A'},
      {izq:'Pertenencia',der:'Movimiento',     eI:'R',eD:'A'}
    ];
    var tDiv=document.getElementById('tensiones-div');
    tDiv.innerHTML='';
    tensiones.forEach(function(t){
      var vi=scores[t.eI],vd=scores[t.eD];
      var pos=(vi+vd===0)?50:Math.round((vd/(vi+vd))*100);
      var row=document.createElement('div');
      row.className='tension-fila';
      row.innerHTML='<span class="tension-polo">'+t.izq+'</span>'
        +'<div class="tension-track"><div class="tension-mid"></div><div class="tension-dot" style="left:'+pos+'%"></div></div>'
        +'<span class="tension-polo d">'+t.der+'</span>';
      tDiv.appendChild(row);
    });

    var fuerte=EJES.reduce(function(a,b){return scores[a]>=scores[b]?a:b;});
    var debil=EJES.reduce(function(a,b){return scores[a]<=scores[b]?a:b;});
    var perfiles={F:'lector/a normativo institucional',O:'lector/a estructural y de procesos',R:'lector/a humano y relacional',A:'lector/a adaptativo y sistémico'};
    var pb=document.getElementById('perfil-bloque');
    pb.innerHTML='<div class="perfil-titulo">Tu perfil: '+perfiles[fuerte]+'</div>'
      +'<div class="perfil-texto">Tu lectura de las situaciones de liderazgo tiende a centrarse en la dimensión <strong>'+nombres[fuerte]+'</strong>. Cuando algo falla, tu primer instinto es buscar causas ahí — lo cual es una fortaleza real y valiosa para el diagnóstico institucional.<br><br>'
      +'La dimensión que aparece con menos énfasis es la <strong>'+nombres[debil]+'</strong>. No significa que la ignorés — significa que no es tu punto de entrada natural. Las situaciones más complejas suelen requerir leer desde múltiples dimensiones simultáneamente.<br><br>'
      +'El objetivo de Pulsos no es que todas las dimensiones sean iguales — es que puedas <strong>elegir conscientemente</strong> desde cuál leer según el problema que enfrentás.</div>';
  }

});
</script>
</body>
</html>
